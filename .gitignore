# Ignore everything by default
*

# Keep directories so unignored files can be reached
!*/

# Keep code files
!*.py
!*.ts
!*.js
!*.json
!*.yml
!*.yaml
!*.sh
!*.bat
!*.cmd
!*.ps1
!*.go
!*.rs
!*.java
!*.c
!*.cpp
!*.h
!*.hpp
!*.cs
!*.swift
!*.kt
!*.kts
!*.php
!*.rb
!*.pl
!*.scala
!*.sql
!*.R
!*.jl
!*.dart
!*.m
!*.fs
!*.fsx

# Keep Markdown files
!*.md
!*.markdown

# Keep this gitignore
!.gitignore

# Ignore dataset, benchmark, and generated output folders
/data/
/results/
.matplotlib/

# Ignore paper output artifacts
/paper/*.pdf
/paper/*.aux
/paper/*.log
/paper/*.out
/paper/*.toc
/paper/*.synctex.gz
